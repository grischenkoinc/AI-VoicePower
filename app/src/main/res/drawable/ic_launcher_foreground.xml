<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="512"
    android:viewportHeight="512">

    <!-- Concentric rings (voice broadcast symbol) -->
    <path
        android:pathData="M256,220m-190,0a190,190 0,1,1 380,0a190,190 0,1,1 -380,0"
        android:strokeWidth="1.5"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeAlpha="0.12"/>
    <path
        android:pathData="M256,220m-160,0a160,160 0,1,1 320,0a160,160 0,1,1 -320,0"
        android:strokeWidth="1"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeAlpha="0.12"/>
    <path
        android:pathData="M256,220m-130,0a130,130 0,1,1 260,0a130,130 0,1,1 -260,0"
        android:strokeWidth="0.8"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeAlpha="0.12"/>

    <!-- Sound waves (left side) -->
    <path
        android:pathData="M148,165 Q118,225 148,285"
        android:strokeWidth="4"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeAlpha="0.5"
        android:strokeLineCap="round"/>
    <path
        android:pathData="M123,140 Q83,225 123,310"
        android:strokeWidth="4"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeAlpha="0.35"
        android:strokeLineCap="round"/>
    <path
        android:pathData="M100,120 Q50,225 100,330"
        android:strokeWidth="4"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeAlpha="0.2"
        android:strokeLineCap="round"/>

    <!-- Sound waves (right side) -->
    <path
        android:pathData="M364,165 Q394,225 364,285"
        android:strokeWidth="4"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeAlpha="0.5"
        android:strokeLineCap="round"/>
    <path
        android:pathData="M389,140 Q429,225 389,310"
        android:strokeWidth="4"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeAlpha="0.35"
        android:strokeLineCap="round"/>
    <path
        android:pathData="M412,120 Q462,225 412,330"
        android:strokeWidth="4"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeAlpha="0.2"
        android:strokeLineCap="round"/>

    <!-- Microphone capsule -->
    <path
        android:pathData="M218,138 A38,38 0,0,1 294,138 L294,188 A38,38 0,0,1 218,188 Z"
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.95"/>

    <!-- Mic grille lines -->
    <group android:alpha="0.5">
        <path android:pathData="M232,132 L280,132" android:strokeWidth="1.5" android:strokeColor="#E5E7EB" android:fillColor="#00000000"/>
        <path android:pathData="M232,147 L280,147" android:strokeWidth="1.5" android:strokeColor="#E5E7EB" android:fillColor="#00000000"/>
        <path android:pathData="M232,162 L280,162" android:strokeWidth="1.5" android:strokeColor="#E5E7EB" android:fillColor="#00000000"/>
        <path android:pathData="M232,177 L280,177" android:strokeWidth="1.5" android:strokeColor="#E5E7EB" android:fillColor="#00000000"/>
        <path android:pathData="M232,192 L280,192" android:strokeWidth="1.5" android:strokeColor="#E5E7EB" android:fillColor="#00000000"/>
    </group>

    <!-- Mic indicator dot (gold) -->
    <path
        android:pathData="M256,117m-5.5,0a5.5,5.5 0,1,1 11,0a5.5,5.5 0,1,1 -11,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="250.5"
                android:startY="111.5"
                android:endX="261.5"
                android:endY="122.5"
                android:type="linear">
                <item android:offset="0" android:color="#FFFBBF24"/>
                <item android:offset="1" android:color="#FFF59E0B"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Mic holder arc -->
    <path
        android:pathData="M195,210 Q195,290 256,290 Q317,290 317,210"
        android:strokeWidth="5.5"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeLineCap="round"/>

    <!-- Mic stand -->
    <path
        android:pathData="M256,290 L256,355"
        android:strokeWidth="5.5"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeLineCap="round"/>

    <!-- Mic base -->
    <path
        android:pathData="M218,355 L294,355"
        android:strokeWidth="5.5"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeLineCap="round"/>

    <!-- AI badge pill -->
    <path
        android:pathData="M240,386 L272,386 A14,14 0,0,1 272,414 L240,414 A14,14 0,0,1 240,386 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="226"
                android:startY="386"
                android:endX="286"
                android:endY="414"
                android:type="linear">
                <item android:offset="0" android:color="#FFFBBF24"/>
                <item android:offset="1" android:color="#FFF59E0B"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- "A" letter -->
    <path
        android:pathData="M244,406 L252,392 L260,406 L255,406 L253.8,403 L250.2,403 L249,406 Z M250.8,401 L253.2,401 L252,398 Z"
        android:fillColor="#1F2937"
        android:fillType="evenOdd"/>

    <!-- "I" letter -->
    <path
        android:pathData="M262,392 L266,392 L266,406 L262,406 Z"
        android:fillColor="#1F2937"/>

    <!-- Sparkle accents -->
    <path
        android:pathData="M370,100 L373,108 L381,111 L373,114 L370,122 L367,114 L359,111 L367,108 Z"
        android:fillColor="#FBBF24"
        android:fillAlpha="0.8"/>
    <path
        android:pathData="M393,132 L395,137 L400,139 L395,141 L393,146 L391,141 L386,139 L391,137 Z"
        android:fillColor="#FBBF24"
        android:fillAlpha="0.5"/>

    <!-- Power dot at base -->
    <path
        android:pathData="M256,362m-4,0a4,4 0,1,1 8,0a4,4 0,1,1 -8,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="252"
                android:startY="358"
                android:endX="260"
                android:endY="366"
                android:type="linear">
                <item android:offset="0" android:color="#FFFBBF24"/>
                <item android:offset="1" android:color="#FFF59E0B"/>
            </gradient>
        </aapt:attr>
    </path>
</vector>
